---
import { SITE } from '../data/site';
import { serviceCategories } from '../data/services';
import { locations } from '../data/locations';
---

<footer class="bg-[#1A1A1A] text-white">
  <div class="max-w-[1200px] mx-auto px-4 md:px-6 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <svg width="32" height="32" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" class="shrink-0">
            <circle cx="18" cy="18" r="17" fill="#00C2D1" stroke="#0B0B0B" stroke-width="2"/>
            <path d="M18 8C18 8 10 16 10 22C10 26.4183 13.5817 30 18 30C22.4183 30 26 26.4183 26 22C26 16 18 8 18 8Z" fill="#FFD200"/>
            <path d="M18 12C18 12 13 18 13 22C13 24.7614 15.2386 27 18 27C20.7614 27 23 24.7614 23 22C23 18 18 12 18 12Z" fill="#0B0B0B"/>
          </svg>
          <span class="font-heading font-bold text-xl text-[#00C2D1]">{SITE.name}</span>
        </div>
        <p class="text-sm text-gray-400 mb-4 leading-relaxed">
          Professional cleaning services for homes and businesses across Salford, Manchester and all Greater Manchester boroughs.
        </p>
        <div class="flex gap-3">
          <a href={SITE.social.facebook} class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center hover:bg-[#00C2D1] transition-colors" aria-label="Facebook">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href={SITE.social.instagram} class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center hover:bg-[#00C2D1] transition-colors" aria-label="Instagram">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-heading font-semibold text-sm uppercase tracking-wider mb-4 text-[#00C2D1]">Quick Links</h4>
        <ul class="space-y-2.5">
          <li><a href="/" class="text-sm text-gray-400 hover:text-white transition-colors">Home</a></li>
          <li><a href="/about" class="text-sm text-gray-400 hover:text-white transition-colors">About Us</a></li>
          <li><a href="/services" class="text-sm text-gray-400 hover:text-white transition-colors">Our Services</a></li>
          <li><a href="/blog" class="text-sm text-gray-400 hover:text-white transition-colors">Blog</a></li>
          <li><a href="/contact" class="text-sm text-gray-400 hover:text-white transition-colors">Contact Us</a></li>
          <li><a href="/get-a-quote" class="text-sm text-gray-400 hover:text-white transition-colors">Get a Quote</a></li>
          <li><a href="/privacy-policy" class="text-sm text-gray-400 hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href="/terms-and-conditions" class="text-sm text-gray-400 hover:text-white transition-colors">Terms & Conditions</a></li>
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="font-heading font-semibold text-sm uppercase tracking-wider mb-4 text-[#00C2D1]">Our Services</h4>
        <ul class="space-y-2.5">
          {serviceCategories.map(service => (
            <li>
              <a href={`/services/${service.slug}`} class="text-sm text-gray-400 hover:text-white transition-colors">
                {service.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="font-heading font-semibold text-sm uppercase tracking-wider mb-4 text-[#00C2D1]">Contact</h4>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 mt-0.5 text-[#00C2D1] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span class="text-sm text-gray-400">{SITE.address.street}, {SITE.address.city}, {SITE.address.postcode}</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-[#00C2D1] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <a href={`tel:${SITE.phoneLink}`} class="text-sm text-gray-400 hover:text-white transition-colors">{SITE.phone}</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-[#00C2D1] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <a href={`mailto:${SITE.email}`} class="text-sm text-gray-400 hover:text-white transition-colors">{SITE.email}</a>
          </li>
        </ul>
        <div class="mt-4 p-3 bg-white/5 rounded-lg">
          <p class="text-xs text-gray-500 font-medium">Business Hours</p>
          {Object.entries(SITE.businessHours).map(([day, hours]) => (
            <div class="flex justify-between text-xs text-gray-400 mt-1">
              <span>{day}</span>
              <span>{hours}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-[1200px] mx-auto px-4 md:px-6 py-6 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-gray-500">
        &copy; {new Date().getFullYear()} {SITE.name}. All rights reserved. Registered in England & Wales.
      </p>
      <div class="flex gap-4 text-xs text-gray-500">
        <a href="/privacy-policy" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/terms-and-conditions" class="hover:text-white transition-colors">Terms & Conditions</a>
        <a href="/crm" class="hover:text-white transition-colors">Admin</a>
      </div>
    </div>
  </div>
</footer>
