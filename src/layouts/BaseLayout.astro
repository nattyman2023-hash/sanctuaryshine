---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Chatbot from '../components/Chatbot.astro';
import { SITE } from '../data/site';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noIndex?: boolean;
  schema?: object;
}

const { title, description, canonical, ogImage, noIndex, schema } = Astro.props;
---

<!DOCTYPE html>
<html lang="en-GB" class="scroll-smooth">
  <head>
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      noIndex={noIndex}
      schema={schema}
    />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <!-- Material Symbols -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,0..200" />
  </head>
  <body class="bg-[#F8FAFB] text-[#191C1D] font-body antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <Chatbot />

    <!-- Mobile Bottom Nav -->
    <nav class="fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 py-3 lg:hidden bg-white shadow-[0_-4px_20px_rgba(0,194,209,0.1)] rounded-t-xl border-t border-gray-100">
      <a href="/" class="flex flex-col items-center justify-center text-[#3C494C]">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        <span class="text-[10px] font-medium mt-0.5">Home</span>
      </a>
      <a href="/services" class="flex flex-col items-center justify-center text-[#3C494C]">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <span class="text-[10px] font-medium mt-0.5">Services</span>
      </a>
      <a href="tel:${SITE.phoneLink}" class="flex flex-col items-center justify-center text-[#3C494C]">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        <span class="text-[10px] font-medium mt-0.5">Call</span>
      </a>
      <a href="/get-a-quote" class="flex flex-col items-center justify-center bg-[#FFD200] text-[#0B0B0B] rounded-full px-5 py-1.5 -mt-2 shadow-md">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        <span class="text-[10px] font-bold mt-0.5">Quote</span>
      </a>
    </nav>
  </body>
</html>