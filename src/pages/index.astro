<script>
  // Contact form handling
  const contactForm = document.getElementById('contact-form');
  if (contactForm) {
    contactForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = contactForm.querySelector('button[type="submit"]');
      const originalText = btn.textContent;
       btn.disabled = true;
       btn.textContent = 'Sending...';
       btn.classList.add('opacity-70');
        try {
          const response = await fetch('/send.php', {
            method: 'POST',
            body: new FormData(contactForm),
            headers: { Accept: 'application/json' }
          });
          const result = await response.json();
          if (!response.ok || result.status !== 'success') throw new Error(result.message || 'Unable to send your message.');
          btn.textContent = 'Message sent — thank you.';
          btn.classList.remove('bg-[#FFD200]', 'hover:bg-[#D6A900]');
          btn.classList.add('bg-green-500', 'text-white');
          contactForm.reset();
        } catch (error) {
          btn.textContent = error instanceof Error ? error.message : 'Unable to send. Please call us.';
          btn.classList.remove('bg-[#FFD200]', 'hover:bg-[#D6A900]');
          btn.classList.add('bg-red-500', 'text-white');
        }
        setTimeout(() => {
          btn.textContent = originalText;
          btn.classList.remove('bg-green-500', 'bg-red-500', 'text-white');
          btn.classList.add('bg-[#FFD200]', 'hover:bg-[#D6A900]');
          btn.disabled = false;
          btn.classList.remove('opacity-70');
        }, 5000);
        return;

       try {
         // Legacy branch is unreachable after the real form submission above.
        await new Promise(resolve => setTimeout(resolve, 1500));
        btn.textContent = '✓ Message Sent!';
        btn.classList.remove('bg-[#FFD200]', 'hover:bg-[#D6A900]');
        btn.classList.add('bg-green-500', 'text-white');
        contactForm.reset();
        setTimeout(() => {
          btn.textContent = originalText;
          btn.classList.remove('bg-green-500', 'text-white');
          btn.classList.add('bg-[#FFD200]', 'hover:bg-[#D6A900]');
          btn.disabled = false;
          btn.classList.remove('opacity-70');
        }, 3000);
      } catch (error) {
        btn.textContent = 'Error sending. Please try again.';
        btn.classList.add('bg-red-500', 'text-white');
        setTimeout(() => {
          btn.textContent = originalText;
          btn.classList.remove('bg-red-500', 'text-white');
          btn.classList.add('bg-[#FFD200]', 'hover:bg-[#D6A900]');
          btn.disabled = false;
          btn.classList.remove('opacity-70');
        }, 3000);
      }
    });
  }
</script>
