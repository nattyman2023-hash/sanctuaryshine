---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../data/site';
import { services, serviceCategories } from '../data/services';
import { locations } from '../data/locations';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What areas do you cover?",
      "acceptedAnswer": { "@type": "Answer", "text": "We cover all Greater Manchester boroughs including Salford, Manchester City Centre, Bolton, Bury, Oldham, Rochdale, Stockport, Tameside, Trafford, and Wigan." }
    },
    {
      "@type": "Question",
      "name": "Are your cleaners insured?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes, all Sanctuary Shine cleaners are fully insured with public liability insurance up to £10 million and are DBS checked." }
    },
    {
      "@type": "Question",
      "name": "Do you provide cleaning products?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes, we bring all cleaning equipment and eco-friendly products. You don't need to provide anything." }
    },
    {
      "@type": "Question",
      "name": "How do I book a cleaning?",
      "acceptedAnswer": { "@type": "Answer", "text": "You can book online through our quote form, call us on 0161 123 4567, or email contact@sanctuaryshine.co.uk. We'll confirm your booking within 2 hours." }
    }
  ]
};
---

<BaseLayout
  title="Reliable Domestic & Commercial Cleaners in Salford and Greater Manchester"
  ogImage="/images/hero-living-room.jpg"
  description="Sanctuary Shine provides professional home, office, deep cleaning, end-of-tenancy and Airbnb cleaning services across Salford, Manchester and Greater Manchester. Get a free quote today."
  schema={faqSchema}
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-white via-[#D9FBFF]/30 to-white">
    <div class="max-w-[1200px] mx-auto px-4 md:px-6 pt-12 pb-16 md:pt-20 md:pb-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div class="animate-fade-in-up">
          <div class="inline-flex items-center gap-2 bg-[#D9FBFF] text-[#008C99] px-3 py-1.5 rounded-full text-xs font-semibold uppercase tracking-wider mb-5">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            Salford & Greater Manchester's Trusted Cleaners
          </div>
          <h1 class="font-heading text-4xl md:text-5xl lg:text-[56px] font-bold leading-tight text-[#0B0B0B] mb-5">
            Reliable Domestic & Commercial Cleaners in <span class="text-[#00C2D1]">Salford</span> and <span class="text-[#00C2D1]">Greater Manchester</span>
          </h1>
          <p class="text-lg md:text-xl text-[#3C494C] mb-8 max-w-xl leading-relaxed">
            Sanctuary Shine provides professional home, office, deep cleaning, end-of-tenancy and Airbnb cleaning services across Salford, Manchester and all Greater Manchester boroughs.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/get-a-quote" class="bg-[#FFD200] text-[#0B0B0B] px-8 py-4 rounded-xl font-bold text-lg hover:bg-[#D6A900] transition-all hover:scale-105 shadow-lg flex items-center gap-2">
              Get a Free Quote
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a href="/services" class="bg-[#00C2D1] text-white px-8 py-4 rounded-xl font-semibold text-lg hover:bg-[#008C99] transition-all hover:scale-105 shadow-md flex items-center gap-2">
              View Services
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </a>
          </div>
          <div class="flex items-center gap-4 mt-8">
            <div class="flex -space-x-2">
              <div class="w-10 h-10 rounded-full border-2 border-white bg-[#00C2D1] flex items-center justify-center text-white text-xs font-bold">JD</div>
              <div class="w-10 h-10 rounded-full border-2 border-white bg-[#FFD200] flex items-center justify-center text-[#0B0B0B] text-xs font-bold">SM</div>
              <div class="w-10 h-10 rounded-full border-2 border-white bg-[#1A1A1A] flex items-center justify-center text-white text-xs font-bold">AK</div>
            </div>
            <div>
              <div class="flex text-[#FFD200]">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              </div>
              <p class="text-sm text-[#3C494C] font-medium">Trusted by 200+ homes and businesses</p>
            </div>
          </div>
        </div>
        <div class="relative animate-fade-in-up-delay-1 hidden lg:block">
          <div class="relative rounded-2xl overflow-hidden shadow-2xl">
            <img src="/images/hero-living-room.jpg" alt="Bright and clean modern living room with natural sunlight streaming through large windows" class="w-full h-auto object-cover" loading="lazy" width="600" height="500" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            <!-- Floating badge -->
            <div class="absolute bottom-4 left-4 bg-[#FFD200] text-[#0B0B0B] px-5 py-3 rounded-xl shadow-lg font-bold text-sm">
              ★ 4.9/5 from 200+ reviews
            </div>
            <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-sm rounded-xl px-4 py-3 shadow-lg">
              <p class="font-semibold text-sm text-[#0B0B0B]">Free Quote Available</p>
              <p class="text-xs text-[#3C494C]">Response within 2 hours</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="bg-white border-y border-gray-100 py-8">
    <div class="max-w-[1200px] mx-auto px-4 md:px-6">
      <div class="flex flex-wrap justify-center gap-8 md:gap-12">
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-full bg-[#D9FBFF] flex items-center justify-center text-[#00C2D1]">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <div>
            <p class="font-semibold text-sm">Fully Insured</p>
            <p class="text-xs text-[#3C494C]">£10m public liability</p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-full bg-[#D9FBFF] flex items-center justify-center text-[#00C2D1]">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          </div>
          <div>
            <p class="font-semibold text-sm">DBS Checked</p>
            <p class="text-xs text-[#3C494C]">Vetted professionals</p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-full bg-[#D9FBFF] flex items-center justify-center text-[#00C2D1]">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <p class="font-semibold text-sm">Eco-Friendly</p>
            <p class="text-xs text-[#3C494C]">Safe for pets & kids</p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-full bg-[#D9FBFF] flex items-center justify-center text-[#00C2D1]">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <p class="font-semibold text-sm">Flexible Scheduling</p>
            <p class="text-xs text-[#3C494C]">One-off or regular visits</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="py-16 md:py-20">
    <div class="max-w-[1200px] mx-auto px-4 md:px-6">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-[#0B0B0B] mb-4">Our Cleaning Services</h2>
        <p class="text-lg text-[#3C494C] max-w-2xl mx-auto">Professional cleaning tailored to your needs — whether it's your home, office, or rental property.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(service => (
          <a href={`/services/${service.slug}`} class="group bg-white rounded-xl p-6 border border-gray-100 hover:border-[#00C2D1]/30 hover:shadow-lg transition-all duration-300">
            <div class="w-12 h-12 rounded-lg bg-[#D9FBFF] flex items-center justify-center text-[#00C2D1] mb-4 group-hover:bg-[#00C2D1] group-hover:text-white transition-all">
              <span class="material-symbols-outlined text-2xl">{service.icon}</span>
            </div>
            <h3 class="font-heading font-semibold text-lg mb-2 group-hover:text-[#00C2D1] transition-colors">{service.title}</h3>
            <p class="text-sm text-[#3C494C] mb-4">{service.tagline}</p>
            <div class="flex items-center justify-between">
              <span class="text-sm font-semibold text-[#00C2D1]">From {service.priceFrom}</span>
              <span class="text-sm text-[#3C494C] group-hover:text-[#00C2D1] flex items-center gap-1 transition-colors">
                Learn more
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-[1200px] mx-auto px-4 md:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-[#0B0B0B] mb-6">Why Choose Sanctuary Shine?</h2>
          <p class="text-lg text-[#3C494C] mb-8">We're not just another cleaning company. Here's what makes us different:</p>
          <div class="space-y-5">
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-full bg-[#D9FBFF] flex items-center justify-center text-[#00C2D1] shrink-0 mt-1">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <div>
                <h3 class="font-semibold text-lg">Local Greater Manchester Team</h3>
                <p class="text-sm text-[#3C494C]">We're based in Salford and know the area inside out. No call centres, no franchises — just local people serving local communities.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-full bg-[#D9FBFF] flex items-center justify-center text-[#00C2D1] shrink-0 mt-1">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <div>
                <h3 class="font-semibold text-lg">Fully Professional Service</h3>
                <p class="text-sm text-[#3C494C]">DBS-checked staff, £10m public liability insurance, COSHH-compliant products, and rigorous quality checks on every visit.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-full bg-[#D9FBFF] flex items-center justify-center text-[#00C2D1] shrink-0 mt-1">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <div>
                <h3 class="font-semibold text-lg">Flexible Cleaning Plans</h3>
                <p class="text-sm text-[#3C494C]">One-off deep cleans, weekly maintenance, or bespoke schedules. We work around your life, not the other way around.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-full bg-[#D9FBFF] flex items-center justify-center text-[#00C2D1] shrink-0 mt-1">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <div>
                <h3 class="font-semibold text-lg">Eco-Friendly & Safe</h3>
                <p class="text-sm text-[#3C494C]">We use biodegradable, non-toxic cleaning products that are safe for your family, pets, and the environment.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="bg-gradient-to-br from-[#00C2D1] to-[#008C99] rounded-2xl p-8 text-white">
          <div class="text-5xl font-heading font-bold mb-2">200+</div>
          <p class="text-lg opacity-90 mb-6">Happy customers across Greater Manchester</p>
          <div class="space-y-4">
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-[#FFD200]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <span>4.9/5 average rating</span>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-[#FFD200]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <span>98% satisfaction rate</span>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-[#FFD200]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <span>Same-week availability</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Areas We Cover -->
  <section class="py-16 md:py-20">
    <div class="max-w-[1200px] mx-auto px-4 md:px-6">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-[#0B0B0B] mb-4">Areas We Cover</h2>
        <p class="text-lg text-[#3C494C] max-w-2xl mx-auto">We provide professional cleaning services across all ten boroughs of Greater Manchester.</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
        {locations.map(loc => (
          <a href={`/areas/${loc.urlSlug}`} class="group bg-white rounded-xl p-4 border border-gray-100 hover:border-[#00C2D1]/30 hover:shadow-md transition-all text-center">
            <div class="w-10 h-10 rounded-full bg-[#D9FBFF] flex items-center justify-center text-[#00C2D1] mx-auto mb-2 group-hover:bg-[#00C2D1] group-hover:text-white transition-all">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <span class="text-sm font-medium group-hover:text-[#00C2D1] transition-colors">{loc.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-[1200px] mx-auto px-4 md:px-6">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-[#0B0B0B] mb-4">How It Works</h2>
        <p class="text-lg text-[#3C494C] max-w-2xl mx-auto">Getting started with Sanctuary Shine is simple.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-[#FFD200] text-[#0B0B0B] flex items-center justify-center text-2xl font-bold mx-auto mb-4">1</div>
          <h3 class="font-semibold text-lg mb-2">Get a Quote</h3>
          <p class="text-sm text-[#3C494C]">Fill in our quick form or give us a call. We'll provide a transparent, no-obligation quote within 2 hours.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-[#FFD200] text-[#0B0B0B] flex items-center justify-center text-2xl font-bold mx-auto mb-4">2</div>
          <h3 class="font-semibold text-lg mb-2">Book Your Clean</h3>
          <p class="text-sm text-[#3C494C]">Choose your date and time. We'll send a vetted, professional cleaner to your home or business.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-[#FFD200] text-[#0B0B0B] flex items-center justify-center text-2xl font-bold mx-auto mb-4">3</div>
          <h3 class="font-semibold text-lg mb-2">We Clean</h3>
          <p class="text-sm text-[#3C494C]">Our team arrives with all equipment and eco-friendly products. We follow a thorough checklist for every visit.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-[#FFD200] text-[#0B0B0B] flex items-center justify-center text-2xl font-bold mx-auto mb-4">4</div>
          <h3 class="font-semibold text-lg mb-2">Enjoy Your Sanctuary</h3>
          <p class="text-sm text-[#3C494C]">Relax and enjoy your spotless space. If you're not happy, we'll re-clean for free.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 md:py-20">
    <div class="max-w-[1200px] mx-auto px-4 md:px-6">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-[#0B0B0B] mb-4">What Our Customers Say</h2>
        <p class="text-lg text-[#3C494C] max-w-2xl mx-auto">Don't just take our word for it. Here's what our customers in Greater Manchester have to say.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm">
          <div class="flex text-[#FFD200] mb-3">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
